---
layout: base.njk
pagination:
  data: site.floorplans
  size: 1
  alias: plan
permalink: "/floor-plans/{{ plan.slug }}/"
eleventyComputed:
  title: "{{ plan.name }} Apartment — Mona Shores Flats"
  description: "{{ plan.blurb }}"
---

<section class="section" style="padding-top:clamp(110px,14vw,180px)">
  <div class="wrap">
    <a class="fp-back" href="/floor-plans/">← All floor plans</a>
    <div class="fp">
      <div class="fp__media"><img src="{{ plan.img }}" alt="{{ plan.name }} apartment at Mona Shores Flats"></div>
      <div>
        <div class="eyebrow">{{ plan.name }}{% if plan.accessible %} · ADA Accessible{% endif %}</div>
        <div class="fp__price">${{ plan.price }}<span> /mo starting</span></div>
        <dl class="fp__meta">
          <div><dt>Bedrooms</dt><dd>{{ plan.beds }}</dd></div>
          <div><dt>Bathrooms</dt><dd>{{ plan.baths }}</dd></div>
          <div><dt>Square Feet</dt><dd>{{ plan.sqft }}</dd></div>
        </dl>
        <p class="lead">{{ plan.blurb }}</p>
        <div class="eyebrow" style="margin-top:22px">Room features</div>
        <ul class="plan__features" style="margin-top:10px">
          {% for f in plan.features %}<li>{{ f }}</li>{% endfor %}
        </ul>
        <div class="fp__actions">
          <a class="btn btn--accent btn--lg" href="{{ site.urls.apply }}" target="_blank" rel="noopener">Apply Now →</a>
          <a class="btn btn--ghost btn--lg" href="{{ site.urls.availability }}" target="_blank" rel="noopener">Check Availability</a>
          <a class="btn btn--ghost btn--lg" href="/contact/#tour">Schedule a Tour</a>
        </div>
      </div>
    </div>

    <div class="grid" style="grid-template-columns:repeat(3,1fr);margin-top:clamp(28px,4vw,48px)">
      {% for p in plan.photos %}
      <figure style="border-radius:var(--r-md);overflow:hidden;aspect-ratio:4/3"><img src="{{ p }}" alt="{{ plan.name }} interior" loading="lazy" style="width:100%;height:100%;object-fit:cover"></figure>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section cta">
  <div class="wrap stack center">
    <h2>Make the {{ plan.name }} yours.</h2>
    <p>{{ site.special }}</p>
    <div class="cta__actions">
      <a class="btn btn--light btn--lg" href="/contact/#tour">Schedule a Tour</a>
      <a class="btn btn--accent btn--lg" href="{{ site.urls.apply }}" target="_blank" rel="noopener">Apply Now →</a>
    </div>
  </div>
</section>
