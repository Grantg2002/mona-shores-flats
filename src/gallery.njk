---
layout: base.njk
title: "Photo Gallery | Mona Shores Flats"
description: "Photos of Mona Shores Flats — granite kitchens, open living areas, bedrooms, baths and the brand-new 2025 community in Norton Shores, MI."
---

<section class="section" style="padding-top:clamp(110px,14vw,180px)">
  <div class="wrap">
    <div class="stack" data-reveal>
      <div class="eyebrow">Gallery</div>
      <h2>Take a closer look.</h2>
      <p class="lead">Real photos of our homes and community. Tap any image to view it full-screen.</p>
    </div>

    <div class="filters" data-reveal>
      <button class="filter is-active" data-filter="all">All</button>
      <button class="filter" data-filter="Interiors">Interiors</button>
      <button class="filter" data-filter="Kitchens">Kitchens</button>
      <button class="filter" data-filter="Bedrooms & Baths">Bedrooms &amp; Baths</button>
      <button class="filter" data-filter="Exterior">Exterior</button>
    </div>

    <div class="masonry" id="gallery">
      {% for g in site.gallery %}
      <figure data-reveal data-cat="{{ g.cat }}" data-full="{{ g.src }}" data-cap="{{ g.cap }}">
        <img src="{{ g.src }}" alt="{{ g.cap }}" loading="lazy">
        <figcaption>{{ g.cap }}</figcaption>
      </figure>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="lb" id="lb" role="dialog" aria-modal="true" aria-label="Photo viewer">
  <button class="lb__btn lb__close" id="lbClose" aria-label="Close">×</button>
  <button class="lb__btn lb__nav lb__prev" id="lbPrev" aria-label="Previous">‹</button>
  <img id="lbImg" src="" alt="">
  <button class="lb__btn lb__nav lb__next" id="lbNext" aria-label="Next">›</button>
  <div class="lb__cap" id="lbCap"></div>
</div>

<section class="section cta">
  <div class="wrap stack center">
    <h2>Like what you see?</h2>
    <p>{{ site.special }}</p>
    <div class="cta__actions">
      <a class="btn btn--light btn--lg" href="/contact/#tour">Schedule a Tour</a>
      <a class="btn btn--accent btn--lg" href="{{ site.urls.apply }}" target="_blank" rel="noopener">Apply Now →</a>
    </div>
  </div>
</section>

<script src="/assets/js/gallery.js" defer></script>
