---
layout: base.njk
title: "Contact & Schedule a Tour | Mona Shores Flats"
description: "Schedule a tour of Mona Shores Flats in Norton Shores, MI. Tours 7 days a week. Call or text (616) 737-8592."
---

<section id="tour" class="section" style="padding-top:clamp(110px,14vw,180px)">
  <div class="wrap">
    <div class="stack" data-reveal style="margin-bottom:clamp(22px,3vw,36px)">
      <div class="eyebrow">Get in Touch</div>
      <h2>Come see it in person.</h2>
      <p class="lead">Tours 7 days a week — leave your info below and we'll follow up the same day. Want to move faster? You can apply or check live availability right now.</p>
      <div class="cta__actions" style="margin-top:6px">
        <a class="btn btn--accent btn--lg" href="{{ site.urls.apply }}" target="_blank" rel="noopener">Apply Now →</a>
        <a class="btn btn--ghost btn--lg" href="{{ site.urls.availability }}" target="_blank" rel="noopener">Check Live Availability</a>
        <a class="btn btn--ghost btn--lg" href="/floor-plans/">Browse Floor Plans</a>
      </div>
    </div>

    <div class="contact">
      {% set funnelId = "tour-form" %}
      {% include "tour-funnel.njk" %}

      <aside class="stack">
        <div class="c-row"><div class="c-label">Address</div><div class="c-val">{{ site.address.street }}<br>{{ site.address.city }}, {{ site.address.region }} {{ site.address.zip }}</div></div>
        <div class="c-row"><div class="c-label">Phone / Text</div><div class="c-val"><a href="tel:{{ site.phoneRaw }}">{{ site.phone }}</a> · <a href="sms:{{ site.phoneRaw }}">Text us</a></div></div>
        <div class="c-row"><div class="c-label">Email</div><div class="c-val"><a href="mailto:{{ site.email }}">{{ site.email }}</a></div></div>
        <div class="c-row"><div class="c-label">Hours</div><div class="c-val">{{ site.hours }}</div></div>
        <div class="c-row"><div class="c-label">Residents</div><div class="c-val"><a href="{{ site.urls.resident }}" target="_blank" rel="noopener">Resident login ↗</a></div></div>
      </aside>
    </div>
  </div>
</section>

{% block scripts %}
<script src="/assets/js/funnel.js" defer></script>
{% endblock %}
