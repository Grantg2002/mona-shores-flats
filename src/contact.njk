---
layout: base.njk
title: "Contact & Schedule a Tour | Mona Shores Flats"
description: "Schedule a tour of Mona Shores Flats in Norton Shores, MI. Tours 7 days a week. Call or text (616) 737-8592."
---

<section class="section" style="padding-top:clamp(110px,14vw,180px)">
  <div class="wrap">
    <div class="stack" data-reveal style="margin-bottom:clamp(28px,4vw,48px)">
      <div class="eyebrow">Get in Touch</div>
      <h2>Come see it in person.</h2>
      <p class="lead">Tours available 7 days a week — it takes about 30 seconds to request one below, and we follow up the same day.</p>
    </div>

    <div class="contact">
      <aside class="stack">
        <div class="c-row"><div class="c-label">Address</div><div class="c-val">{{ site.address.street }}<br>{{ site.address.city }}, {{ site.address.region }} {{ site.address.zip }}</div></div>
        <div class="c-row"><div class="c-label">Phone / Text</div><div class="c-val"><a href="tel:{{ site.phoneRaw }}">{{ site.phone }}</a> · <a href="sms:{{ site.phoneRaw }}">Text us</a></div></div>
        <div class="c-row"><div class="c-label">Email</div><div class="c-val"><a href="mailto:{{ site.email }}">{{ site.email }}</a></div></div>
        <div class="c-row"><div class="c-label">Hours</div><div class="c-val">{{ site.hours }}</div></div>
        <div class="c-row"><div class="c-label">Residents & Applicants</div><div class="c-val">
          <a href="{{ site.urls.apply }}" target="_blank" rel="noopener">Apply online ↗</a><br>
          <a href="{{ site.urls.resident }}" target="_blank" rel="noopener">Resident login ↗</a>
        </div></div>
      </aside>

      {% set funnelId = "tour" %}
      {% include "tour-funnel.njk" %}
    </div>
  </div>
</section>

{% block scripts %}
<script src="/assets/js/funnel.js" defer></script>
{% endblock %}
