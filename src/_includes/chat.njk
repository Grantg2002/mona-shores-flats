<button class="chat-fab" id="chatFab" aria-label="Chat with us">💬</button>
<div class="chat-panel" id="chatPanel" role="dialog" aria-label="Leasing chat assistant">
  <div class="chat-head">
    <div class="chat-head__av">🏠</div>
    <div class="chat-head__t">
      <strong>Mona Shores Flats</strong>
      <span>Typically replies in minutes</span>
    </div>
    <button class="chat-head__close" id="chatClose" aria-label="Close chat">×</button>
  </div>
  <div class="chat-body" id="chatBody"></div>
  <div class="chat-chips" id="chatChips"></div>
  <div class="chat-input">
    <input id="chatInput" type="text" placeholder="Type a question…" autocomplete="off">
    <button id="chatSend" aria-label="Send">➤</button>
  </div>
</div>
