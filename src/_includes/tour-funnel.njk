<div id="{{ funnelId or 'tour' }}" class="panel" data-funnel data-intent="Tour Request">
  <h3 style="margin-bottom:6px">Schedule a Tour</h3>
  <p class="muted" style="font-size:.9rem;margin-bottom:20px">No obligation · we follow up the same day</p>

  <div class="step is-active" data-step="0">
    <div class="field-row">
      <div class="field"><label>First name</label><input name="firstName" placeholder="Jane" autocomplete="given-name" required></div>
      <div class="field"><label>Last name</label><input name="lastName" placeholder="Smith" autocomplete="family-name"></div>
    </div>
    <div class="field"><label>Phone</label><input name="phone" data-phone inputmode="tel" placeholder="(616) 555-0100" autocomplete="tel" required></div>
    <div class="field"><label>Email</label><input name="email" type="email" placeholder="jane@email.com" autocomplete="email"></div>
    <div class="field">
      <label>Bedrooms <span class="muted" style="font-weight:400">(optional)</span></label>
      <select name="bedrooms" class="select">
        <option value="">No preference</option>
        <option>1 Bedroom</option>
        <option>2 Bedroom</option>
        <option>3 Bedroom</option>
      </select>
    </div>
    <button type="button" class="btn btn--accent btn--block btn--lg" data-submit>Request My Tour</button>
    <p class="muted" style="font-size:.76rem;margin-top:12px">Prefer to skip ahead? <a href="{{ site.urls.apply }}" target="_blank" rel="noopener" style="color:var(--accent);font-weight:600">Apply online →</a> or call/text <a href="tel:{{ site.phoneRaw }}" style="color:var(--accent);font-weight:600">{{ site.phone }}</a>.</p>
  </div>

  <div class="step" data-step="success" style="text-align:center;padding:14px 0">
    <div style="font-size:2rem">✓</div>
    <h3 style="margin:8px 0 6px">You're all set!</h3>
    <p class="muted" data-success-msg style="font-size:.92rem">We'll follow up shortly to confirm your tour.</p>
    <div style="margin-top:18px"><a class="btn btn--accent btn--lg" href="{{ site.urls.apply }}" target="_blank" rel="noopener">Or start your application →</a></div>
  </div>
</div>
